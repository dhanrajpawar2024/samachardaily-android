<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG-ONLY network security override.
  Allows cleartext for local development IPs (emulator 10.0.2.2 and LAN).
  Also trusts user-installed CA certificates for Charles Proxy / mitmproxy.
  This file lives in src/debug and is NOT included in release builds.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <!-- Emulator host + common LAN ranges -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>

