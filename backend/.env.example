# ============================================================
#  SamacharDaily — Environment Variables
#  Copy this to .env and fill in real values before running.
#  NEVER commit .env to git.
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=samachar_daily
POSTGRES_USER=sd_user
POSTGRES_PASSWORD=<your-secure-postgres-password>
DATABASE_URL=postgresql://sd_user:<password>@postgres:5432/samachar_daily

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<your-secure-redis-password>
REDIS_URL=redis://:<password>@redis:6379/0

# ── Kafka ───────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=samachar-daily
KAFKA_GROUP_ID=sd-consumers

# Kafka Topics
KAFKA_TOPIC_CLICKSTREAM=clickstream
KAFKA_TOPIC_ARTICLE_INGESTION=article_ingestion
KAFKA_TOPIC_BREAKING_NEWS=breaking_news
KAFKA_TOPIC_NOTIFICATION_EVENTS=notification_events
KAFKA_TOPIC_FEED_INVALIDATION=feed_invalidation

# ── Elasticsearch ───────────────────────────────────────────
ES_HOST=http://elasticsearch:9200
ES_USERNAME=elastic
ES_PASSWORD=<your-secure-elasticsearch-password>
ES_INDEX_ARTICLES=sd_articles
ES_INDEX_VIDEOS=sd_videos

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=<your-super-secret-random-string-min-32-chars>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<another-super-secret-random-string-min-32-chars>
JWT_REFRESH_EXPIRES_IN=30d

# ── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# ── NewsAPI ──────────────────────────────────────────────────
NEWSAPI_KEY=<your-newsapi-key-from-newsapi.org>
NEWS_API_BASE_URL=https://newsapi.org/v2
RSS_FEEDS=https://feeds.reuters.com/reuters/india,https://feeds.news18.com/rss/hindi
INGESTION_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_FETCH=100

# ── Firebase ─────────────────────────────────────────────────
FIREBASE_PROJECT_ID=<your-firebase-project-id>
FIREBASE_PRIVATE_KEY_ID=<your-firebase-private-key-id>
FIREBASE_PRIVATE_KEY=<your-firebase-private-key>
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=<your-firebase-client-id>

# ── AWS S3 / CloudFront ─────────────────────────────────────
AWS_ACCESS_KEY_ID=<your-aws-access-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-key>
AWS_REGION=ap-south-1
AWS_S3_BUCKET=samachar-daily-media
CLOUDFRONT_BASE_URL=https://<your-cloudfront-domain>.cloudfront.net

# ── Feed Service Ranking Weights ────────────────────────────
# Must sum to 1.0
RECENCY_WEIGHT=0.20
TRENDING_WEIGHT=0.30
AFFINITY_WEIGHT=0.40
ENGAGEMENT_WEIGHT=0.10
FEED_CACHE_TTL_MINUTES=5
MIN_AFFINITY_THRESHOLD=0.1

# ── Search Service Configuration ────────────────────────────
SEARCH_CACHE_TTL_MINUTES=5

# ── Service Ports ───────────────────────────────────────────
PORT_GATEWAY=3000
PORT_AUTH=3001
PORT_CONTENT=3002
PORT_FEED=3003
PORT_SEARCH=3004
PORT_NOTIFICATION=3005

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=*

# ── AdMob / Ad Manager ──────────────────────────────────────
ADMOB_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX

